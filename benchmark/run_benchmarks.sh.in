#!/usr/bin/env bash
# Generated by CMake — do not edit directly.
# Run from the build directory: bash benchmark/run_benchmarks.sh
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SOURCE_DIR="@CMAKE_SOURCE_DIR@"
BINARY_DIR="@CMAKE_BINARY_DIR@"
PYTHON_EXE="@Python3_EXECUTABLE@"

FIXTURE_SMALL="@FIXTURE_SMALL@"
FIXTURE_MEDIUM="@FIXTURE_MEDIUM@"
FIXTURE_LARGE="@FIXTURE_LARGE@"
FLIGHT_SERVER="@CMAKE_BINARY_DIR@/flight_server/rag-flight-server"
PYTHONPATH_RAG="@CMAKE_BINARY_DIR@/python"
RESULTS_DIR="${SOURCE_DIR}/benchmark/results"

mkdir -p "${RESULTS_DIR}"

echo "=== RNTuple-Arrow-Gateway Benchmark Suite ==="
echo ""

# ── System info ──────────────────────────────────────────────────────────────
SYSINFO="${RESULTS_DIR}/system_info.txt"
{
  echo "date: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
  echo "os: $(uname -srm)"
  echo "cpu: $(grep 'model name' /proc/cpuinfo | head -1 | cut -d: -f2 | xargs)"
  echo "cores_logical: $(nproc)"
  echo "ram_gb: $(awk '/MemTotal/{printf "%.1f", $2/1024/1024}' /proc/meminfo)"
  echo "python: $(${PYTHON_EXE} --version 2>&1)"
  echo "pyarrow: $(${PYTHON_EXE} -c 'import pyarrow; print(pyarrow.__version__)')"
  echo "uproot: $(${PYTHON_EXE} -c 'import uproot; print(uproot.__version__)')"
  echo "awkward: $(${PYTHON_EXE} -c 'import awkward; print(awkward.__version__)')"
  echo "arrow_cpp: 19.0.0"
  echo "fixture_small: ${FIXTURE_SMALL}"
  echo "fixture_medium: ${FIXTURE_MEDIUM}"
  echo "fixture_large: ${FIXTURE_LARGE}"
  for f in small medium large; do
      FVAR="FIXTURE_$(echo ${f} | tr a-z A-Z)"
      FPATH="${!FVAR}"
      if [ -f "${FPATH}" ]; then
          SIZE=$(du -sh "${FPATH}" | cut -f1)
          echo "fixture_${f}_size_disk: ${SIZE}"
      fi
  done
} > "${SYSINFO}"
echo "[1/4] System info written to ${SYSINFO}"

# ── C++ benchmark ────────────────────────────────────────────────────────────
echo "[2/4] Running C++ path benchmark..."
"${BINARY_DIR}/benchmark/bench_cpp_path" \
    --benchmark_format=json \
    --benchmark_out="${RESULTS_DIR}/cpp_path.json" \
    --benchmark_repetitions=3 \
    --benchmark_report_aggregates_only=true
echo "      → ${RESULTS_DIR}/cpp_path.json"

# ── Python path benchmark ─────────────────────────────────────────────────────
echo "[3/4] Running Python path benchmark..."
PYTHONPATH="${PYTHONPATH_RAG}" \
FIXTURE_SMALL="${FIXTURE_SMALL}" \
FIXTURE_MEDIUM="${FIXTURE_MEDIUM}" \
FIXTURE_LARGE="${FIXTURE_LARGE}" \
RESULTS_DIR="${RESULTS_DIR}" \
"${PYTHON_EXE}" "${SOURCE_DIR}/benchmark/bench_python_path.py"
echo "      → ${RESULTS_DIR}/python_path.csv"

# ── Flight benchmark ──────────────────────────────────────────────────────────
echo "[4/4] Running Flight localhost benchmark..."
PYTHONPATH="${PYTHONPATH_RAG}" \
FIXTURE_SMALL="${FIXTURE_SMALL}" \
FIXTURE_MEDIUM="${FIXTURE_MEDIUM}" \
FIXTURE_LARGE="${FIXTURE_LARGE}" \
FLIGHT_SERVER="${FLIGHT_SERVER}" \
RESULTS_DIR="${RESULTS_DIR}" \
"${PYTHON_EXE}" "${SOURCE_DIR}/benchmark/bench_flight.py"
echo "      → ${RESULTS_DIR}/flight.csv"

# ── Plots ─────────────────────────────────────────────────────────────────────
echo "[done] Generating plots..."
RESULTS_DIR="${RESULTS_DIR}" \
"${PYTHON_EXE}" "${SOURCE_DIR}/benchmark/plot_results.py"
echo "       → ${RESULTS_DIR}/*.png"

echo ""
echo "All results in ${RESULTS_DIR}/"
